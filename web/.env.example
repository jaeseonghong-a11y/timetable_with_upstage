# Set this only in web/.env.local for local development and in Vercel's server-side environment settings.
# Never prefix this variable with NEXT_PUBLIC_.
UPSTAGE_API_KEY=

# Used only by /api/parse-curriculum-roadmap (학과별 교육과정 로드맵 이미지 분석). Upstage remains
# the core of the service for every other document-parsing feature — this is a documented, scoped
# exception (see docs/roadmap-on-demand.md).
GEMINI_API_KEY=
# Optional overrides; defaults live in the route itself.
# GEMINI_MODEL=gemini-3.5-flash
# GEMINI_FALLBACK_MODEL=gemini-3.1-flash-lite
